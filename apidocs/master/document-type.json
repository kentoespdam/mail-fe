			"url": "http://192.168.1.214:8081",
			"description": "Generated server url"
		}
	],
	"security": [
		{
			"Bearer Token": []
		}
	],
	"paths": {
		"/api/v1/document-types": {
			"get": {
				"tags": ["document-type-controller"],
				"operationId": "list",
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/DocumentTypeDto"
									}
								}
							}
						}
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"DocumentTypeDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "integer",
						"format": "int32"
					},
					"name": {
						"type": "string"
					}
				}
			}
		},
		"securitySchemes": {
			"Bearer Token": {
				"type": "http",
				"name": "Bearer Token",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		}
	}
