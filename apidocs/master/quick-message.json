{
	"openapi": "3.1.0",
	"info": {
		"title": "Mail Service API",
		"description": "API untuk manajemen surat digital PERUMDAMTS",
		"contact": {
			"name": "PERUMDAMTS",
			"email": "admin@perumdamts.id"
		},
		"version": "1.0.0"
	},
	"servers": [
		{
			"url": "http://192.168.1.214:8081",
			"description": "Generated server url"
		}
	],
	"security": [
		{
			"Bearer Token": []
		}
	],
	"paths": {
		"/api/v1/quick-messages/{id}": {
			"get": {
				"tags": ["quick-message-controller"],
				"operationId": "findById",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "integer",
							"format": "int32"
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/QuickMessageResponse"
								}
							}
						}
					}
				}
			},
			"put": {
				"tags": ["quick-message-controller"],
				"operationId": "update",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "integer",
							"format": "int32"
						}
					}
				],
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/QuickMessageRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/QuickMessageResponse"
								}
							}
						}
					}
				}
			},
			"delete": {
				"tags": ["quick-message-controller"],
				"operationId": "delete",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "integer",
							"format": "int32"
						}
					}
				],
				"responses": {
					"204": {
						"description": "No Content"
					}
				}
			}
		},
		"/api/v1/quick-messages": {
			"get": {
				"tags": ["quick-message-controller"],
				"operationId": "findAll",
				"parameters": [
					{
						"name": "page",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32",
							"default": 0
						}
					},
					{
						"name": "size",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32",
							"default": 20
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PageQuickMessageResponse"
								}
							}
						}
					}
				}
			},
			"post": {
				"tags": ["quick-message-controller"],
				"operationId": "create",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/QuickMessageRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/QuickMessageResponse"
								}
							}
						}
					}
				}
			}
		},
		"/api/v1/quick-messages/lookup": {
			"get": {
				"tags": ["quick-message-controller"],
				"operationId": "lookup",
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/QuickMessageResponse"
									}
								}
							}
						}
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"QuickMessageResponse": {
				"type": "object",
				"properties": {
					"id": {
						"type": "integer",
						"format": "int32"
					},
					"message": {
						"type": "string"
					}
				}
			},
			"QuickMessageRequest": {
				"type": "object",
				"properties": {
					"message": {
						"type": "string",
						"maxLength": 128,
						"minLength": 0
					}
				},
				"required": ["message"]
			},
			"PageQuickMessageResponse": {
				"type": "object",
				"properties": {
					"totalPages": {
						"type": "integer",
						"format": "int32"
					},
					"totalElements": {
						"type": "integer",
						"format": "int64"
					},
					"size": {
						"type": "integer",
						"format": "int32"
					},
					"content": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/QuickMessageResponse"
						}
					},
					"number": {
						"type": "integer",
						"format": "int32"
					},
					"pageable": {
						"$ref": "#/components/schemas/PageableObject"
					},
					"sort": {
						"$ref": "#/components/schemas/SortObject"
					},
					"numberOfElements": {
						"type": "integer",
						"format": "int32"
					},
					"first": {
						"type": "boolean"
					},
					"last": {
						"type": "boolean"
					},
					"empty": {
						"type": "boolean"
					}
				}
			},
			"PageableObject": {
				"type": "object",
				"properties": {
					"offset": {
						"type": "integer",
						"format": "int64"
					},
					"unpaged": {
						"type": "boolean"
					},
					"paged": {
						"type": "boolean"
					},
					"pageNumber": {
						"type": "integer",
						"format": "int32"
					},
					"pageSize": {
						"type": "integer",
						"format": "int32"
					},
					"sort": {
						"$ref": "#/components/schemas/SortObject"
					}
				}
			},
			"SortObject": {
				"type": "object",
				"properties": {
					"empty": {
						"type": "boolean"
					},
					"unsorted": {
						"type": "boolean"
					},
					"sorted": {
						"type": "boolean"
					}
				}
			}
		},
		"securitySchemes": {
			"Bearer Token": {
				"type": "http",
				"name": "Bearer Token",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		}
	}
}
