{
	"openapi": "3.1.0",
	"info": {
		"title": "Mail Service API",
		"description": "API untuk manajemen surat digital PERUMDAMTS",
		"contact": {
			"name": "PERUMDAMTS",
			"email": "admin@perumdamts.id"
		},
		"version": "1.0.0"
	},
	"servers": [
		{
			"url": "http://192.168.1.214:8081",
			"description": "Generated server url"
		}
	],
	"security": [
		{
			"Bearer Token": []
		}
	],
	"paths": {
		"/api/v1/publications/{id}": {
			"get": {
				"tags": [
					"publication-controller"
				],
				"operationId": "findById",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PublicationDto"
								}
							}
						}
					}
				}
			},
			"put": {
				"tags": [
					"publication-controller"
				],
				"operationId": "update",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"requestBody": {
					"content": {
						"multipart/form-data": {
							"schema": {
								"type": "object",
								"properties": {
									"data": {
										"$ref": "#/components/schemas/UpdatePublicationRequest"
									},
									"file": {
										"type": "string",
										"format": "binary"
									}
								},
								"required": [
									"data"
								]
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PublicationDto"
								}
							}
						}
					}
				}
			},
			"delete": {
				"tags": [
					"publication-controller"
				],
				"operationId": "delete",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"204": {
						"description": "No Content"
					}
				}
			}
		},
		"/api/v1/publications": {
			"get": {
				"tags": [
					"publication-controller"
				],
				"operationId": "list",
				"parameters": [
					{
						"name": "status",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string",
							"enum": [
								"DRAFT",
								"PUBLISHED",
								"DELETED"
							]
						}
					},
					{
						"name": "keyword",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "typeId",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32"
						}
					},
					{
						"name": "startDate",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date"
						}
					},
					{
						"name": "endDate",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date"
						}
					},
					{
						"name": "sortBy",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "sortDir",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "page",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32"
						}
					},
					{
						"name": "size",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32"
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PagedResponsePublicationDto"
								}
							}
						}
					}
				}
			},
			"post": {
				"tags": [
					"publication-controller"
				],
				"operationId": "create",
				"requestBody": {
					"content": {
						"multipart/form-data": {
							"schema": {
								"type": "object",
								"properties": {
									"data": {
										"$ref": "#/components/schemas/CreatePublicationRequest"
									},
									"file": {
										"type": "string",
										"format": "binary"
									}
								},
								"required": [
									"data"
								]
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PublicationDto"
								}
							}
						}
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"PublicationDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string"
					},
					"title": {
						"type": "string"
					},
					"description": {
						"type": "string"
					},
					"documentType": {
						"$ref": "#/components/schemas/DocumentTypeDto"
					},
					"status": {
						"type": "string"
					},
					"publishedDate": {
						"type": "string",
						"format": "date-time"
					},
					"fileName": {
						"type": "string"
					},
					"filePath": {
						"type": "string"
					},
					"fileSize": {
						"type": "integer",
						"format": "int32"
					},
					"createdByName": {
						"type": "string"
					},
					"createdByTitle": {
						"type": "string"
					},
					"createdByUserId": {
						"type": "integer",
						"format": "int32"
					},
					"createdAt": {
						"type": "string",
						"format": "date-time"
					},
					"updatedAt": {
						"type": "string",
						"format": "date-time"
					},
					"totalCount": {
						"type": "integer",
						"format": "int32"
					}
				}
			},
			"UpdatePublicationRequest": {
				"type": "object",
				"properties": {
					"title": {
						"type": "string",
						"minLength": 1
					},
					"description": {
						"type": "string"
					},
					"documentTypeId": {
						"type": "integer",
						"format": "int32"
					},
					"publish": {
						"type": "boolean"
					}
				},
				"required": [
					"documentTypeId",
					"title"
				]
			},
			"PagedResponsePublicationDto": {
				"type": "object",
				"properties": {
					"content": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/PublicationDto"
						}
					},
					"page": {
						"type": "integer",
						"format": "int32"
					},
					"size": {
						"type": "integer",
						"format": "int32"
					},
					"totalElements": {
						"type": "integer",
						"format": "int64"
					},
					"totalPages": {
						"type": "integer",
						"format": "int32"
					},
					"first": {
						"type": "boolean"
					},
					"last": {
						"type": "boolean"
					}
				}
			},
			"CreatePublicationRequest": {
				"type": "object",
				"properties": {
					"title": {
						"type": "string",
						"minLength": 1
					},
					"description": {
						"type": "string"
					},
					"documentTypeId": {
						"type": "integer",
						"format": "int32"
					},
					"publish": {
						"type": "boolean"
					}
				},
				"required": [
					"documentTypeId",
					"title"
				]
			},
			"DocumentTypeDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "integer",
						"format": "int32"
					},
					"name": {
						"type": "string"
					}
				}
			}
		},
		"securitySchemes": {
			"Bearer Token": {
				"type": "http",
				"name": "Bearer Token",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		}
	}
}