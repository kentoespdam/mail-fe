{
	"openapi": "3.1.0",
	"info": {
		"title": "Mail Service API",
		"description": "API untuk manajemen surat digital PERUMDAMTS",
		"contact": {
			"name": "PERUMDAMTS",
			"email": "admin@perumdamts.id"
		},
		"version": "1.0.0"
	},
	"servers": [
		{
			"url": "http://192.168.1.214:8081",
			"description": "Generated server url"
		}
	],
	"security": [
		{
			"Bearer Token": []
		}
	],
	"paths": {
		"/api/v1/mail/folders/{id}": {
			"put": {
				"tags": [
					"mail-folder-controller"
				],
				"operationId": "renameFolder",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/MailFolderRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/MailFolderResponse"
								}
							}
						}
					}
				}
			},
			"delete": {
				"tags": [
					"mail-folder-controller"
				],
				"operationId": "deleteFolder",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"204": {
						"description": "No Content"
					}
				}
			}
		},
		"/api/v1/mail/folders/move": {
			"put": {
				"tags": [
					"mail-folder-controller"
				],
				"operationId": "moveMails",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/MoveMailRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "OK"
					}
				}
			}
		},
		"/api/v1/mail/mails/{id}/restore": {
			"post": {
				"tags": [
					"mail-folder-controller"
				],
				"operationId": "restoreMail_1",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"204": {
						"description": "No Content"
					}
				}
			}
		},
		"/api/v1/mail/mails/{id}/delete": {
			"post": {
				"tags": [
					"mail-folder-controller"
				],
				"operationId": "deleteMail_1",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"204": {
						"description": "No Content"
					}
				}
			}
		},
		"/api/v1/mail/folders": {
			"get": {
				"tags": [
					"mail-folder-controller"
				],
				"operationId": "getFolderTree",
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/MailFolderResponse"
									}
								}
							}
						}
					}
				}
			},
			"post": {
				"tags": [
					"mail-folder-controller"
				],
				"operationId": "createFolder",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/MailFolderRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/MailFolderResponse"
								}
							}
						}
					}
				}
			}
		},
		"/api/v1/mail/folders/{id}/mails": {
			"get": {
				"tags": [
					"mail-folder-controller"
				],
				"operationId": "getMailsInFolder",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "keyword",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "sdate",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date"
						}
					},
					{
						"name": "edate",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date"
						}
					},
					{
						"name": "sortBy",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "sortDir",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "page",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32",
							"minimum": 0
						}
					},
					{
						"name": "size",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32",
							"maximum": 100,
							"minimum": 1
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/MailSummaryResponse"
									}
								}
							}
						}
					}
				}
			}
		},
		"/api/v1/mail/folders/counters": {
			"get": {
				"tags": [
					"mail-folder-controller"
				],
				"operationId": "getCounters",
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/FolderCounterResponse"
									}
								}
							}
						}
					}
				}
			}
		},
		"/api/v1/mail/trash": {
			"delete": {
				"tags": [
					"mail-folder-controller"
				],
				"operationId": "emptyTrash",
				"responses": {
					"204": {
						"description": "No Content"
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"MailFolderRequest": {
				"type": "object",
				"properties": {
					"name": {
						"type": "string",
						"maxLength": 45,
						"minLength": 0
					},
					"parentFolderId": {
						"type": "string",
						"minLength": 1
					}
				},
				"required": [
					"name",
					"parentFolderId"
				]
			},
			"MailFolderResponse": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string"
					},
					"parentFolderId": {
						"type": "string"
					},
					"ownerId": {
						"type": "string"
					},
					"name": {
						"type": "string"
					},
					"iconCls": {
						"type": "string"
					},
					"system": {
						"type": "boolean"
					},
					"unread": {
						"type": "integer",
						"format": "int64"
					},
					"total": {
						"type": "integer",
						"format": "int64"
					}
				}
			},
			"MoveMailRequest": {
				"type": "object",
				"properties": {
					"mailIds": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"minItems": 1
					},
					"fromFolderId": {
						"type": "string",
						"minLength": 1
					},
					"toFolderId": {
						"type": "string",
						"minLength": 1
					}
				},
				"required": [
					"fromFolderId",
					"mailIds",
					"toFolderId"
				]
			},
			"MailSummaryResponse": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string"
					},
					"mailNumber": {
						"type": "string"
					},
					"mailDate": {
						"type": "string",
						"format": "date"
					},
					"subject": {
						"type": "string"
					},
					"audit": {
						"$ref": "#/components/schemas/MailAuditInfoDto"
					},
					"summary": {
						"$ref": "#/components/schemas/MailSummaryInfoDto"
					},
					"readStatus": {
						"type": "integer",
						"format": "int32"
					},
					"folderId": {
						"type": "string"
					},
					"type": {
						"$ref": "#/components/schemas/MailTypeLookup"
					},
					"category": {
						"$ref": "#/components/schemas/MailCategoryLookup"
					},
					"circulationName": {
						"type": "string"
					},
					"restoreFolder": {
						"$ref": "#/components/schemas/MailFolderLookup"
					},
					"thread": {
						"$ref": "#/components/schemas/MailThreadInfoDto"
					},
					"totalCount": {
						"type": "integer",
						"format": "int64"
					}
				}
			},
			"FolderCounterResponse": {
				"type": "object",
				"properties": {
					"folderId": {
						"type": "string"
					},
					"folderName": {
						"type": "string"
					},
					"unread": {
						"type": "integer",
						"format": "int64"
					},
					"total": {
						"type": "integer",
						"format": "int64"
					},
					"id": {
						"type": "string"
					}
				}
			},
			"MailAuditInfoDto": {
				"type": "object",
				"properties": {
					"createdBy": {
						"type": "string"
					},
					"createdByName": {
						"type": "string"
					},
					"createdDate": {
						"type": "string",
						"format": "date-time"
					},
					"updatedDate": {
						"type": "string",
						"format": "date-time"
					}
				}
			},
			"MailSummaryInfoDto": {
				"type": "object",
				"properties": {
					"attachmentQty": {
						"type": "integer",
						"format": "int32"
					},
					"toStr": {
						"type": "string"
					}
				}
			},
			"MailTypeLookup": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string"
					},
					"name": {
						"type": "string"
					}
				}
			},
			"MailCategoryLookup": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string"
					},
					"name": {
						"type": "string"
					}
				}
			},
			"MailFolderLookup": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string"
					},
					"name": {
						"type": "string"
					}
				}
			},
			"MailThreadInfoDto": {
				"type": "object",
				"properties": {
					"rootMailId": {
						"type": "string"
					},
					"parentMailId": {
						"type": "string"
					}
				}
			}
		},
		"securitySchemes": {
			"Bearer Token": {
				"type": "http",
				"name": "Bearer Token",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		}
	}
}