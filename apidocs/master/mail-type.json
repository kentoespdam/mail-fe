	"components": {
		"schemas": {
			"MailTypeResponse": {
				"type": "object",
				"properties": {
					"id": {
						"type": "integer",
						"format": "int32"
					},
					"name": {
						"type": "string"
					},
					"status": {
						"type": "string",
						"enum": [
							"ACTIVE",
							"INACTIVE",
							"DELETED"
						]
					},
					"categoryCount": {
						"type": "integer",
						"format": "int64"
					}
				}
			},
			"MailTypeRequest": {
				"type": "object",
				"properties": {
					"name": {
						"type": "string",
						"maxLength": 32,
						"minLength": 0
					}
				},
				"required": [
					"name"
				]
			},
			"Pageable": {
				"type": "object",
				"properties": {
					"page": {
						"type": "integer",
						"format": "int32",
						"minimum": 0
					},
					"size": {
						"type": "integer",
						"format": "int32",
						"minimum": 1
					},
					"sort": {
						"type": "array",
						"items": {
							"type": "string"
						}
					}
				}
			},
			"PageMailTypeResponse": {
				"type": "object",
				"properties": {
					"totalPages": {
						"type": "integer",
						"format": "int32"
					},
					"totalElements": {
						"type": "integer",
						"format": "int64"
					},
					"size": {
						"type": "integer",
						"format": "int32"
					},
					"content": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/MailTypeResponse"
						}
					},
					"number": {
						"type": "integer",
						"format": "int32"
					},
					"pageable": {
						"$ref": "#/components/schemas/PageableObject"
					},
					"sort": {
						"$ref": "#/components/schemas/SortObject"
					},
					"numberOfElements": {
						"type": "integer",
						"format": "int32"
					},
					"first": {
						"type": "boolean"
					},
					"last": {
						"type": "boolean"
					},
					"empty": {
						"type": "boolean"
					}
				}
			},
			"MailTypeLookup": {
				"type": "object",
				"properties": {
					"id": {
						"type": "integer",
						"format": "int32"
					},
					"name": {
						"type": "string"
					}
				}
			},
			"PageableObject": {
				"type": "object",
				"properties": {
					"offset": {
						"type": "integer",
						"format": "int64"
					},
					"unpaged": {
						"type": "boolean"
					},
					"paged": {
						"type": "boolean"
					},
					"pageNumber": {
						"type": "integer",
						"format": "int32"
					},
					"pageSize": {
						"type": "integer",
						"format": "int32"
					},
					"sort": {
						"$ref": "#/components/schemas/SortObject"
					}
				}
			},
			"SortObject": {
				"type": "object",
				"properties": {
					"empty": {
						"type": "boolean"
					},
					"unsorted": {
						"type": "boolean"
					},
					"sorted": {
						"type": "boolean"
					}
				}
			}
		},
		"securitySchemes": {
			"Bearer Token": {
				"type": "http",
				"name": "Bearer Token",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
