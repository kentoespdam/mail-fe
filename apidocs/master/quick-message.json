{
	"openapi": "3.1.0",
	"info": {
		"title": "Mail Service API",
		"description": "API untuk manajemen surat digital PERUMDAMTS",
		"contact": {
			"name": "PERUMDAMTS",
			"email": "admin@perumdamts.id"
		},
		"version": "1.0.0"
	},
	"servers": [
		{
			"url": "http://192.168.1.214:8081",
			"description": "Generated server url"
		}
	],
	"security": [
		{
			"Bearer Token": []
		}
	],
	"paths": {
		"/api/v1/quick-messages/{id}": {
			"get": {
				"tags": [
					"quick-message-controller"
				],
				"operationId": "findById",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/QuickMessageResponse"
								}
							}
						}
					}
				}
			},
			"put": {
				"tags": [
					"quick-message-controller"
				],
				"operationId": "update",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/QuickMessageRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/QuickMessageResponse"
								}
							}
						}
					}
				}
			},
			"delete": {
				"tags": [
					"quick-message-controller"
				],
				"operationId": "delete",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"204": {
						"description": "No Content"
					}
				}
			}
		},
		"/api/v1/quick-messages": {
			"get": {
				"tags": [
					"quick-message-controller"
				],
				"operationId": "findAll",
				"parameters": [
					{
						"name": "search",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "status",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string",
							"enum": [
								"ACTIVE",
								"INACTIVE",
								"DELETED"
							]
						}
					},
					{
						"name": "sortBy",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "sortDir",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "page",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32",
							"minimum": 0
						}
					},
					{
						"name": "size",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32",
							"maximum": 100,
							"minimum": 1
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PagedModelQuickMessageResponse"
								}
							}
						}
					}
				}
			},
			"post": {
				"tags": [
					"quick-message-controller"
				],
				"operationId": "create",
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/QuickMessageRequest"
							}
						}
					},
					"required": true
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/QuickMessageResponse"
								}
							}
						}
					}
				}
			}
		},
		"/api/v1/quick-messages/{id}/status": {
			"patch": {
				"tags": [
					"quick-message-controller"
				],
				"operationId": "toggleStatus",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/QuickMessageResponse"
								}
							}
						}
					}
				}
			}
		},
		"/api/v1/quick-messages/lookup": {
			"get": {
				"tags": [
					"quick-message-controller"
				],
				"operationId": "lookup",
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "#/components/schemas/QuickMessageResponse"
									}
								}
							}
						}
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"QuickMessageResponse": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string"
					},
					"message": {
						"type": "string"
					}
				}
			},
			"QuickMessageRequest": {
				"type": "object",
				"properties": {
					"message": {
						"type": "string",
						"maxLength": 128,
						"minLength": 0
					}
				},
				"required": [
					"message"
				]
			},
			"PagedModelQuickMessageResponse": {
				"type": "object",
				"properties": {
					"content": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/QuickMessageResponse"
						}
					},
					"page": {
						"$ref": "#/components/schemas/PageMetadata"
					}
				}
			},
			"PageMetadata": {
				"type": "object",
				"properties": {
					"size": {
						"type": "integer",
						"format": "int64"
					},
					"number": {
						"type": "integer",
						"format": "int64"
					},
					"totalElements": {
						"type": "integer",
						"format": "int64"
					},
					"totalPages": {
						"type": "integer",
						"format": "int64"
					}
				}
			}
		},
		"securitySchemes": {
			"Bearer Token": {
				"type": "http",
				"name": "Bearer Token",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		}
	}
}