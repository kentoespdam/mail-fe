									"$ref": "#/components/schemas/PublicationResponse"
								}
							}
						}
					}
				}
			},
			"put": {
				"tags": [
					"publication-controller"
				],
				"operationId": "update",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"requestBody": {
					"content": {
						"multipart/form-data": {
							"schema": {
								"$ref": "#/components/schemas/UpdatePublicationRequest"
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
