{
	"openapi": "3.1.0",
	"info": {
		"title": "Mail Service API",
		"description": "API untuk manajemen surat digital PERUMDAMTS",
		"contact": {
			"name": "PERUMDAMTS",
			"email": "admin@perumdamts.id"
		},
		"version": "1.0.0"
	},
	"servers": [
		{
			"url": "http://192.168.1.214:8081",
			"description": "Generated server url"
		}
	],
	"security": [
		{
			"Bearer Token": []
		}
	],
	"paths": {
		"/api/v1/document-types": {
			"get": {
				"tags": [
					"document-type-controller"
				],
				"operationId": "list",
				"parameters": [
					{
						"name": "search",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "sortBy",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "sortDir",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "page",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32"
						}
					},
					{
						"name": "size",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32"
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PagedModelDocumentTypeDto"
								}
							}
						}
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"PagedModelDocumentTypeDto": {
				"type": "object",
				"properties": {
					"content": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/DocumentTypeDto"
						}
					},
					"page": {
						"$ref": "#/components/schemas/PageMetadata"
					}
				}
			},
			"DocumentTypeDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "integer",
						"format": "int32"
					},
					"name": {
						"type": "string"
					}
				}
			},
			"PageMetadata": {
				"type": "object",
				"properties": {
					"size": {
						"type": "integer",
						"format": "int64"
					},
					"number": {
						"type": "integer",
						"format": "int64"
					},
					"totalElements": {
						"type": "integer",
						"format": "int64"
					},
					"totalPages": {
						"type": "integer",
						"format": "int64"
					}
				}
			}
		},
		"securitySchemes": {
			"Bearer Token": {
				"type": "http",
				"name": "Bearer Token",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		}
	}
}