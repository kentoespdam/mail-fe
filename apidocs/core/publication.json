							"type": "string"
						}
					}
				],
				"responses": {
					"204": {
						"description": "No Content"
					}
				}
			}
		},
		"/api/v1/publications": {
			"get": {
				"tags": [
					"publication-controller"
				],
				"operationId": "findAll",
				"parameters": [
					{
						"name": "status",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string",
							"enum": [
								"DRAFT",
								"PUBLISHED",
								"DELETED"
							]
						}
					},
					{
						"name": "keyword",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "typeId",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "startDate",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date"
						}
					},
					{
						"name": "endDate",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date"
						}
					},
					{
						"name": "sortBy",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "sortDir",
						"in": "query",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "page",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32"
						}
					},
					{
						"name": "size",
						"in": "query",
						"required": false,
						"schema": {
							"type": "integer",
							"format": "int32"
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PagedModelPublicationResponse"
								}
							}
						}
					}
				}
			},
			"post": {
				"tags": [
					"publication-controller"
				],
				"operationId": "create",
				"requestBody": {
					"content": {
						"multipart/form-data": {
							"schema": {
								"$ref": "#/components/schemas/CreatePublicationRequest"
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PublicationResponse"
								}
							}
						}
					}
				}
			}
		},
		"/api/v1/publications/{id}/publish": {
			"patch": {
				"tags": [
					"publication-controller"
				],
				"operationId": "publish_1",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"$ref": "#/components/schemas/PublicationResponse"
								}
							}
						}
					}
				}
			}
		},
		"/api/v1/publications/{id}/download": {
			"get": {
				"tags": [
					"publication-controller"
				],
				"operationId": "download",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string"
						}
					}
				],
				"responses": {
					"200": {
						"description": "OK",
						"content": {
							"*/*": {
								"schema": {
									"type": "string",
									"format": "binary"
								}
							}
						}
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"PublicationResponse": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string"
					},
					"title": {
						"type": "string"
					},
					"description": {
						"type": "string"
					},
					"documentType": {
						"$ref": "#/components/schemas/DocumentTypeLookup"
					},
					"status": {
						"type": "string"
					},
					"publishedDate": {
						"type": "string",
						"format": "date-time"
					},
					"fileName": {
						"type": "string"
					},
					"fileSize": {
						"type": "integer",
						"format": "int32"
					},
					"createdByName": {
						"type": "string"
					},
					"createdByTitle": {
						"type": "string"
					},
					"createdByUserId": {
						"type": "string"
					},
					"createdAt": {
						"type": "string",
						"format": "date-time"
					},
					"updatedAt": {
						"type": "string",
						"format": "date-time"
					}
				}
			},
			"UpdatePublicationRequest": {
				"type": "object",
				"properties": {
					"title": {
						"type": "string",
						"minLength": 1
					},
					"description": {
						"type": "string"
					},
					"documentTypeId": {
						"type": "string",
						"minLength": 1
					},
					"publish": {
						"type": "boolean"
					},
					"file": {
						"type": "string",
						"format": "binary"
					}
				},
				"required": [
					"documentTypeId",
					"title"
				]
			},
			"PagedModelPublicationResponse": {
				"type": "object",
				"properties": {
					"content": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/PublicationResponse"
						}
					},
					"page": {
						"$ref": "#/components/schemas/PageMetadata"
					}
				}
			},
			"CreatePublicationRequest": {
				"type": "object",
				"properties": {
					"title": {
						"type": "string",
						"minLength": 1
					},
					"description": {
						"type": "string"
					},
					"documentTypeId": {
						"type": "string",
						"minLength": 1
					},
					"publish": {
						"type": "boolean"
					},
					"file": {
						"type": "string",
						"format": "binary"
					}
				},
				"required": [
					"documentTypeId",
					"title"
				]
			},
			"DocumentTypeLookup": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string"
					},
					"name": {
						"type": "string"
					}
				}
			},
			"PageMetadata": {
				"type": "object",
				"properties": {
					"size": {
						"type": "integer",
						"format": "int64"
					},
					"number": {
						"type": "integer",
						"format": "int64"
					},
					"totalElements": {
						"type": "integer",
						"format": "int64"
					},
					"totalPages": {
						"type": "integer",
						"format": "int64"
					}
				}
			}
		},
		"securitySchemes": {
			"Bearer Token": {
				"type": "http",
				"name": "Bearer Token",
				"scheme": "bearer",
				"bearerFormat": "JWT"
			}
		}
	}
}